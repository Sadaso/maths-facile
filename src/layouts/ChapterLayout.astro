---
import BaseLayout from './BaseLayout.astro';
import { levelsData, findChapterBySlug } from '../data/levels.js';
import { getChapterContent } from '../data/content.js';
import { renderMath } from '../utils/katex.js';

interface Props {
  level: string;
  slug: string;
}

const { level, slug } = Astro.props;
const levelData = levelsData[level];
const chapter = findChapterBySlug(level, slug);
const content = getChapterContent(level, chapter.id);

const chapters = levelData.chapters;
const idx = chapters.findIndex(ch => ch.slug === slug);
const prev = idx > 0 ? chapters[idx - 1] : null;
const next = idx < chapters.length - 1 ? chapters[idx + 1] : null;

const seoTitle = `${chapter.title} — Cours ${levelData.title} Maths | Maths Facile`;
const seoDesc = `Cours complet de ${chapter.title} en ${levelData.title} : définitions, propriétés, démonstrations et méthodes. Exercices corrigés et fiche de révision.`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LearningResource",
  "name": chapter.title,
  "description": seoDesc,
  "educationalLevel": levelData.title,
  "provider": { "@type": "Organization", "name": "Maths Facile", "url": "https://maths-facile.com" },
  "isAccessibleForFree": true,
  "inLanguage": "fr",
};

// Block type rendering helpers
const blockTypes = {
  definition: { className: 'block-definition', label: 'Définition' },
  theorem: { className: 'block-theorem', label: 'Théorème' },
  property: { className: 'block-theorem', label: 'Propriété' },
  method: { className: 'block-example', label: 'Méthode' },
  example: { className: 'block-example', label: 'Exemple' },
  remark: { className: 'block-remark', label: 'Remarque' },
  proof: { className: 'block-proof', label: 'Démonstration' },
};

function renderBlock(block) {
  if (block.type === 'text' && block.value) {
    return renderMath(block.value);
  }
  if (block.type === 'table' && block.headers) {
    const ths = block.headers.map(h => `<th>${renderMath(h)}</th>`).join('');
    const rows = block.rows.map(row =>
      `<tr>${row.map(cell => `<td>${renderMath(cell)}</td>`).join('')}</tr>`
    ).join('');
    return `<div class="course-table-wrapper"><table class="course-table"><thead><tr>${ths}</tr></thead><tbody>${rows}</tbody></table></div>`;
  }
  const bt = blockTypes[block.type];
  if (bt && block.value) {
    const title = block.title ? renderMath(block.title) : bt.label;
    return `<div class="${bt.className}"><div class="block-title">${title}</div><div>${renderMath(block.value)}</div></div>`;
  }
  return '';
}

function renderSection(section) {
  let html = '';
  if (section.title) html += `<h2>${renderMath(section.title)}</h2>`;
  if (section.subtitle) html += `<h3>${renderMath(section.subtitle)}</h3>`;
  if (section.content) {
    for (const block of section.content) {
      html += renderBlock(block);
    }
  }
  return html;
}
---

<BaseLayout title={seoTitle} description={seoDesc} jsonLd={jsonLd}>
  <!-- Breadcrumbs with schema.org -->
  <nav aria-label="Fil d'Ariane" class="breadcrumbs">
    <a href="/">Accueil</a> &gt; <a href={`/${level}/`}>{levelData.title}</a> &gt; {chapter.title}
  </nav>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://maths-facile.com/" },
      { "@type": "ListItem", "position": 2, "name": levelData.title, "item": `https://maths-facile.com/${level}/` },
      { "@type": "ListItem", "position": 3, "name": chapter.title },
    ]
  })} />

  <!-- Tab navigation (static HTML, JS toggles visibility) -->
  <div class="chapter-tabs">
    <div class="chapter-tabs-inner">
      <button class="tab-btn active" data-tab="cours">Cours</button>
      <button class="tab-btn" data-tab="fiche">Fiche de cours</button>
      <button class="tab-btn" data-tab="exercices">Exercices</button>
      <button class="tab-btn" data-tab="problemes">Problèmes de synthèse</button>
    </div>
  </div>

  <div class="chapter-content">
    <h1 style="color: var(--blue-950); text-align: center; margin-bottom: 2rem;">
      {chapter.title}
    </h1>

    <!-- COURS — pre-rendered KaTeX at build time -->
    <article id="tab-cours" class="tab-panel active">
      <div class="course-document">
        {content?.cours?.map(section => (
          <div class="course-section" set:html={renderSection(section)} />
        ))}
      </div>
    </article>

    <!-- FICHE — pre-rendered KaTeX at build time -->
    <article id="tab-fiche" class="tab-panel" style="display:none;">
      <div class="course-document">
        {content?.fiche?.map(section => (
          <div class="course-section" set:html={renderSection(section)} />
        ))}
        {(!content?.fiche || content.fiche.length === 0) && (
          <div class="placeholder">
            <h2>Contenu à venir</h2>
            <p>La fiche de cours est en cours de rédaction.</p>
          </div>
        )}
      </div>
    </article>

    <!-- EXERCICES — React interactive (hydrated on visibility) -->
    <section id="tab-exercices" class="tab-panel" style="display:none;">
      <slot name="exercices" />
    </section>

    <!-- PROBLEMES — React interactive -->
    <section id="tab-problemes" class="tab-panel" style="display:none;">
      <slot name="problemes" />
    </section>
  </div>

  <!-- Prev/Next navigation -->
  <nav class="chapter-nav-prevnext" aria-label="Navigation entre chapitres">
    {prev ? (
      <a href={`/${level}/${prev.slug}/`} class="chapter-nav-link prev">
        <span class="chapter-nav-arrow">←</span>
        <span class="chapter-nav-text">
          <span class="chapter-nav-label">Chapitre précédent</span>
          <span class="chapter-nav-title">{prev.title}</span>
        </span>
      </a>
    ) : <span />}
    {next ? (
      <a href={`/${level}/${next.slug}/`} class="chapter-nav-link next">
        <span class="chapter-nav-text">
          <span class="chapter-nav-label">Chapitre suivant</span>
          <span class="chapter-nav-title">{next.title}</span>
        </span>
        <span class="chapter-nav-arrow">→</span>
      </a>
    ) : <span />}
  </nav>

  <!-- Link to Bac subjects -->
  <section style="text-align:center; padding: 2rem;">
    <h2 style="color: var(--blue-950);">S'entraîner avec les sujets du bac</h2>
    <a href="/sujets-bac-maths/" class="nav-cta" style="display:inline-flex; padding: 0.8rem 1.5rem; margin-top:0.5rem;">
      Voir les sujets corrigés →
    </a>
  </section>

  <!-- Tab switching script -->
  <script>
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-panel').forEach(p => p.style.display = 'none');
        btn.classList.add('active');
        const panel = document.getElementById('tab-' + btn.dataset.tab);
        if (panel) panel.style.display = '';
      });
    });
  </script>
</BaseLayout>

<style>
  .breadcrumbs {
    padding: 1rem 2rem;
    font-size: 0.85rem;
    color: var(--slate-500);
  }
  .breadcrumbs a { color: var(--blue-600); text-decoration: none; }
</style>
