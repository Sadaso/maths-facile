---
import ChapterLayout from "../../layouts/ChapterLayout.astro";
import ExerciseList from "../../components/ExerciseList.jsx";
import { getChapterContent } from "../../data/content.js";

const content = getChapterContent("terminale", 7);
---

<ChapterLayout level="terminale" slug="fonction-exponentielle">
  <ExerciseList client:visible exercises={content?.exercices} slot="exercices" />
  <ExerciseList client:visible exercises={content?.problemes} isProblems slot="problemes" />
</ChapterLayout>
