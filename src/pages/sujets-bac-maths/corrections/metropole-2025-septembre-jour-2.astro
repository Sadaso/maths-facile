---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { tex } from '../../../utils/katex.js';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "name": "Corrigé Bac Maths 2025 Métropole Septembre Jour 2",
  "description": "Correction détaillée du sujet de mathématiques spécialité du baccalauréat 2025, Métropole Septembre Jour 2, 10 septembre 2025.",
  "datePublished": "2025-09-10",
  "author": { "@type": "Organization", "name": "Maths Facile", "url": "https://maths-facile.com" },
  "publisher": { "@type": "Organization", "name": "Maths Facile" },
