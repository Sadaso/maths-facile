---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sujets2025, sujets2024 } from '../../data/sujetsBac.js';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Sujets Bac Maths — Annales corrigées",
  "description": "Tous les sujets du bac de mathématiques (spécialité) 2024 et 2025 avec liens vers les corrigés.",
  "provider": { "@type": "Organization", "name": "Maths Facile" },
};
---

<BaseLayout
  title="Sujets Bac Maths 2024-2025 — Annales corrigées spécialité | Maths Facile"
  description="Retrouvez tous les sujets du baccalauréat de mathématiques (spécialité) 2024 et 2025 : Métropole, Amérique du Nord, Asie, Polynésie, et plus."
  jsonLd={jsonLd}
>
  <nav aria-label="Fil d'Ariane" class="breadcrumbs">
    <a href="/">Accueil</a> &gt; Sujets Bac Maths
  </nav>

  <div class="container section" style="text-align:center;">
    <h1 style="color:var(--blue-950);">Sujets du Bac Maths</h1>
    <p style="color:var(--slate-600); max-width:600px; margin:0.5rem auto 2rem;">
      Tous les sujets officiels du baccalauréat de mathématiques (spécialité) avec liens vers les énoncés et corrigés sur l'APMEP.
    </p>

    <div class="bac-sessions">
      <a href="/sujets-bac-maths/2025/" class="bac-session-card">
        <div class="bac-session-year">2025</div>
        <div class="bac-session-count">{sujets2025.length} sujets</div>
        <div class="bac-session-desc">Session en cours</div>
      </a>
      <a href="/sujets-bac-maths/2024/" class="bac-session-card">
        <div class="bac-session-year">2024</div>
        <div class="bac-session-count">{sujets2024.length} sujets</div>
        <div class="bac-session-desc">Session complète</div>
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  .breadcrumbs { padding: 1rem 2rem; font-size: 0.85rem; color: var(--slate-500); }
  .breadcrumbs a { color: var(--blue-600); text-decoration: none; }
  .bac-sessions { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; max-width: 600px; margin: 0 auto; }
  .bac-session-card {
    background: white; border: 1px solid var(--slate-200); border-radius: 12px;
    padding: 2rem; text-decoration: none; color: inherit;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .bac-session-card:hover { box-shadow: 0 8px 25px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .bac-session-year { font-family: var(--font-heading); font-size: 2.5rem; font-weight: 800; color: var(--blue-600); }
  .bac-session-count { font-size: 1.1rem; font-weight: 600; color: var(--blue-950); margin: 0.25rem 0; }
  .bac-session-desc { font-size: 0.85rem; color: var(--slate-500); }
</style>
