---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Maths Facile" description="Contactez l'équipe Maths Facile pour toute question ou suggestion.">
  <div class="container section" style="max-width:600px; margin:0 auto; padding:3rem 1.5rem;">
    <h1 style="color:var(--blue-950); text-align:center;">Contact</h1>
    <p style="color:var(--slate-600); text-align:center; margin-bottom:2rem;">
      Une question, une suggestion ? N'hésitez pas à nous écrire.
    </p>
    <form class="contact-form" action="#" method="POST">
      <label>Nom <input type="text" name="name" required /></label>
      <label>Email <input type="email" name="email" required /></label>
      <label>Message <textarea name="message" rows="5" required></textarea></label>
      <button type="submit" class="nav-cta" style="width:100%; justify-content:center;">Envoyer</button>
    </form>
  </div>
</BaseLayout>

<style>
  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .contact-form label { display: flex; flex-direction: column; gap: 0.3rem; font-weight: 600; font-size: 0.9rem; color: var(--slate-700); }
  .contact-form input, .contact-form textarea {
    padding: 0.7rem; border: 1px solid var(--slate-300); border-radius: 8px; font-size: 0.95rem;
    font-family: inherit; transition: border-color 0.2s;
  }
  .contact-form input:focus, .contact-form textarea:focus { border-color: var(--blue-600); outline: none; }
</style>
