    exercices: [
  // ─────────────────────────────────────────────
  // FACILES (1-10)
  // ─────────────────────────────────────────────
  {
    number: 1,
    difficulty: 'easy',
    statement: "Calculer $\\displaystyle\\lim_{x \\to 3} (2x^2 - 5x + 1)$.",
    correction: "La fonction $f(x) = 2x^2 - 5x + 1$ est un polynôme, donc continue sur $\\mathbb{R}$.\n\nOn remplace directement $x$ par $3$ :\n$\\displaystyle\\lim_{x \\to 3} (2x^2 - 5x + 1) = 2 \\times 9 - 5 \\times 3 + 1 = 18 - 15 + 1 = \\boxed{4}$"
  },
  {
    number: 2,
    difficulty: 'easy',
    statement: "Calculer $\\displaystyle\\lim_{x \\to +\\infty} (3x^3 - 7x + 2)$.",
    correction: "Pour un polynôme, la limite en $+\\infty$ est donnée par le terme de plus haut degré.\n\n$\\displaystyle\\lim_{x \\to +\\infty} (3x^3 - 7x + 2) = \\lim_{x \\to +\\infty} 3x^3 = \\boxed{+\\infty}$\n\nEn effet, $3x^3 - 7x + 2 = x^3\\left(3 - \\dfrac{7}{x^2} + \\dfrac{2}{x^3}\\right)$ et $x^3 \\to +\\infty$, $3 - \\dfrac{7}{x^2} + \\dfrac{2}{x^3} \\to 3 > 0$."
  },
  {
    number: 3,
    difficulty: 'easy',
    statement: "Calculer $\\displaystyle\\lim_{x \\to +\\infty} \\frac{5x - 3}{2x + 7}$.",
    correction: "On divise numérateur et dénominateur par $x$ (le terme de plus haut degré) :\n\n$\\dfrac{5x - 3}{2x + 7} = \\dfrac{5 - \\dfrac{3}{x}}{2 + \\dfrac{7}{x}}$\n\nOr $\\dfrac{3}{x} \\to 0$ et $\\dfrac{7}{x} \\to 0$ quand $x \\to +\\infty$, donc :\n\n$\\displaystyle\\lim_{x \\to +\\infty} \\frac{5x - 3}{2x + 7} = \\frac{5 - 0}{2 + 0} = \\boxed{\\frac{5}{2}}$\n\nLa droite $y = \\dfrac{5}{2}$ est une asymptote horizontale en $+\\infty$."
  },
  {
    number: 4,
    difficulty: 'easy',
    statement: "Déterminer $\\displaystyle\\lim_{x \\to 2^+} \\frac{1}{x - 2}$.",
